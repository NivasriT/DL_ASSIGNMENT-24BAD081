      <aliases enabled='yes' />
      <column caption='Clean sales' datatype='real' name='[Calculation_0411243615035392]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IFNULL([Sales],0)' />
      </column>
      <column caption='Clean region' datatype='string' name='[Calculation_0411243615166465]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IFNULL([Region],&quot;Unknown&quot;)' />
      </column>
      <column caption='Outlier flag' datatype='string' name='[Calculation_0411243616587778]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Sales] &gt; 10000 THEN&#13;&#10;&quot;Outlier&quot;&#13;&#10;ELSE&#13;&#10;&quot;Normal&quot;&#13;&#10;END' />
      </column>
      <column caption='Profit Ratio' datatype='real' name='[Calculation_1368249927221915648]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit])/SUM([Sales])' />
      </column>
